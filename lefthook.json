{
  "$schema": "https://raw.githubusercontent.com/evilmartians/lefthook/master/schema.json",
  "pre-commit": {
    "commands": {
      "biome": {
        "glob": "*.{js,jsx,ts,tsx,json,css,md,yml,yaml}",
        "run": "pnpm dlx @biomejs/biome check --write {staged_files}",
        "stage_fixed": true
      }
    }
  },
  "pre-push": {
    "commands": {
      "typecheck": {
        "run": "pnpm exec tsc --noEmit"
      }
    }
  },
  "commit-msg": {
    "commands": {
      "empty-commit-guard": {
        "run": "git diff --cached --quiet && (echo \"Empty commit is not allowed.\"; exit 1) || true"
      }
    }
  }
}
